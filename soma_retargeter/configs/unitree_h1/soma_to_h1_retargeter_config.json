{
    "robot_model": {
        "format": "urdf",
        "path": "unitree_h1/h1_with_hand.urdf",
        "floating": true,
        "collapse_fixed_joints": false,
        "hide_visuals": true,
        "parse_visuals_as_colliders": false
    },
    "initialization_pose": "soma/soma_zero_frame0.bvh",
    "num_initialization_frames": 10,
    "num_stabilization_frames": 5,
    "human_robot_scaler_config": "unitree_h1/soma_to_h1_scaler_config_rest_aligned.json",
    "feet_stabilizer_config": "",
    "model_height": 1.80,

    "ik_iterations": 24,
    "joint_limit_weight": 10.0,
    "smooth_joint_filter_weight": 5.5,
    "collision_weight": 0.0,
    "enable_post_processing": false,
    "output_smoothing_window": 7,

    "smooth_joint_filter_objective_body_masks": {
        "left_shoulder_pitch_link": 0.1,
        "left_shoulder_roll_link": 1.0,
        "left_shoulder_yaw_link": 0.3,
        "right_shoulder_pitch_link": 0.1,
        "right_shoulder_roll_link": 1.0,
        "right_shoulder_yaw_link": 0.3
    },

    "ik_map": {
        "Hips": {
            "t_body": "pelvis",
            "r_body": "pelvis",
            "t_weight": 30.0,
            "r_weight": 2.0
        },
        "Chest": {
            "t_body": "torso_link",
            "r_body": "torso_link",
            "t_weight": 0.7,
            "r_weight": 0.7
        },
        "LeftArm": {
            "t_body": "left_shoulder_roll_link",
            "r_body": "left_shoulder_roll_link",
            "t_weight": 1.5,
            "r_weight": 0.15
        },
        "LeftForeArm": {
            "t_body": "left_elbow_link",
            "r_body": "left_elbow_link",
            "t_weight": 1.0,
            "r_weight": 1.0
        },
        "LeftHand": {
            "t_body": "left_hand_link",
            "r_body": "left_hand_link",
            "t_weight": 2.0,
            "r_weight": 1.2
        },
        "RightArm": {
            "t_body": "right_shoulder_roll_link",
            "r_body": "right_shoulder_roll_link",
            "t_weight": 1.5,
            "r_weight": 0.15
        },
        "RightForeArm": {
            "t_body": "right_elbow_link",
            "r_body": "right_elbow_link",
            "t_weight": 1.0,
            "r_weight": 1.0
        },
        "RightHand": {
            "t_body": "right_hand_link",
            "r_body": "right_hand_link",
            "t_weight": 2.0,
            "r_weight": 1.2
        },
        "LeftLeg": {
            "t_body": "left_hip_roll_link",
            "r_body": "left_hip_roll_link",
            "t_weight": 1.5,
            "r_weight": 0.15
        },
        "LeftShin": {
            "t_body": "left_knee_link",
            "r_body": "left_knee_link",
            "t_weight": 1.0,
            "r_weight": 1.0
        },
        "LeftFoot": {
            "t_body": "left_ankle_link",
            "r_body": "left_ankle_link",
            "t_weight": 30.0,
            "r_weight": 2.0
        },
        "RightLeg": {
            "t_body": "right_hip_roll_link",
            "r_body": "right_hip_roll_link",
            "t_weight": 1.5,
            "r_weight": 0.15
        },
        "RightShin": {
            "t_body": "right_knee_link",
            "r_body": "right_knee_link",
            "t_weight": 1.0,
            "r_weight": 1.0
        },
        "RightFoot": {
            "t_body": "right_ankle_link",
            "r_body": "right_ankle_link",
            "t_weight": 30.0,
            "r_weight": 2.0
        }
    }
}
